# Provider credentials and endpoints
# Agent-level default provider/model selection lives in `utils/api_client.py`.
#
# Current agent defaults:
# - task_plan            -> openai   / gpt-4o-mini
# - probe_reasoning      -> openai   / o4-mini
# - probe_optimizer      -> openai   / gpt-4o-mini
# - probe_generator      -> openai   / gpt-4o-mini
# - probe_responder      -> deepseek / deepseek-v4-pro
# - redteam_synthesizer  -> deepseek / deepseek-v4-pro
# - redteam_judge        -> openai   / gpt-4o-2024-08-06
#
# Override behavior:
# - Edit `AGENT_DEFAULTS` in `utils/api_client.py` to switch an agent's default provider/model
# - CLI `--model` values still override the model at runtime
# - If an agent uses an explicit provider such as `openai`, `deepseek`, or `proxy`,
#   that provider is preserved even when you override the model name
# - Automatic provider switching from model prefixes only happens when the agent provider is set to `auto`

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Gemini
# Fill these when you have an OpenAI-compatible Gemini endpoint or a relay route for Gemini.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Grok
# Fill these when you have an OpenAI-compatible Grok endpoint or a relay route for Grok.
GROK_API_KEY=
GROK_BASE_URL=https://api.groq.com/openai/v1

# Claude
# Fill these when you have an OpenAI-compatible Claude endpoint or a relay route for Claude.
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com

# Generic relay / proxy (e.g. OpenRouter, Self-hosted gateway, etc.)
# Example: OpenRouter, Self-hosted gateway, or any other OpenAI-compatible proxy.
PROXY_API_KEY=
PROXY_BASE_URL=
